#!/usr/bin/env sh
# Run ESLint --fix on staged TS files only. The dprint formatter runs as
# an ESLint rule, so --fix handles both formatting and lint-fixable rules.
# If something can't auto-fix, ESLint exits non-zero and blocks the commit.

staged=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx|mjs|cjs)$' || true)

if [ -n "$staged" ]; then
  printf '%s\n' "$staged" | xargs bunx eslint --fix --no-warn-ignored || exit 1
  # Re-stage files that ESLint modified.
  git update-index --again
fi

# Typecheck every workspace package with tsc. Whole-project, can't scope to
# staged files, so it runs in full and blocks the commit on any type error.
bun run typecheck || exit 1
