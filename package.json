{
  "$schema": "https://www.schemastore.org/package.json",
  "name": "parley",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prepare": "husky",
    "typecheck": "bun run --filter '@parley/*' typecheck",
    "build:bin": "bun run --filter '@parley/cli' build:bin && bun run --filter '@parley/api' build:bin",
    "install:bin": "bun run ./scripts/install-bins.ts"
  },
  "devDependencies": {
    "@effect/eslint-plugin": "^0.3.2",
    "@effect/language-service": "^0.86.1",
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "comptime.ts": "^0.8.1",
    "eslint": "^10.4.0",
    "husky": "^9.1.7",
    "typescript-eslint": "^8.60.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@effect/experimental": "^0.60.0",
    "@effect/platform": "^0.96.1",
    "@effect/platform-bun": "^0.89.0",
    "effect": "^3.21.2"
  }
}
